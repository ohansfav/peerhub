run = "cd client && npm install && npm run build && cd ../server && npm install && npm start"

entrypoint = "server/src/server.js"

[env]
NODE_ENV = "production"
JWT_SECRET = "replit-secret-key-change-in-production"
EMAIL_SERVICE = "console"
ADMIN_EMAIL = "admin@peerhub.com"
ADMIN_PASSWORD = "admin123"
DATABASE_URL = "file:./database.sqlite"
PORT = "3000"

[packager]
language = "nodejs"
